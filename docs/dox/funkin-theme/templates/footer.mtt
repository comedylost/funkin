<footer class="section site-footer" style="background:$$getHexValue(::themeColor::)">
	<div class="container">
		<div class="copyright">
			<p ::cond api.isDefined("version")::>This documentation is generated for version ::api.getValue('version')::</p>
			<p>&copy; ::api.config.date.getFullYear():: &nbsp;
				<a ::cond api.isDefined("website"):: ::attr href api.getValue("website")::>The Funkin' Crew Inc</a>
			</p>
		</div>
	</div>
</footer>
